generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Folder {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  teams     Team[]
}

model Team {
  id        Int           @id @default(autoincrement())
  name      String
  folderId  Int
  createdAt DateTime      @default(now())
  folder    Folder        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  pokemon   TeamPokemon[]
}

model TeamPokemon {
  id          Int     @id @default(autoincrement())
  teamId      Int
  pokemonName String
  slot        Int     // 1-6
  nickname    String?
  item        String?
  ability     String?
  move1       String?
  move2       String?
  move3       String?
  move4       String?
  nature      String?
  evs         String? // JSON string: {"hp":0,"atk":0,"def":0,"spa":0,"spd":0,"spe":0}
  ivs         String? // JSON string: {"hp":31,"atk":31,"def":31,"spa":31,"spd":31,"spe":31}
  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, slot])
}
